# ─────────────────────────────────────────────────────────────────────────────
# OpenRemoteGPS stack — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ───────────────────────────────────────────────────────────────────
TZ=Europe/Bucharest
HOSTNAME=gps.unitip.global

# ── Database (timescaledb / postgres) ────────────────────────────────────────
# Backs OpenRemote manager, Keycloak, and is the source for the nightly backup.
POSTGRES_DB=openremote
POSTGRES_USER=openremote
POSTGRES_PASSWORD=__CHANGE_ME__            # was "o_parola_puternica" in Railway — rotate
PGDATA=/home/postgres/pgdata/data

# ── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=__CHANGE_ME__      # was "Admin" in Railway — rotate
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://timescaledb:5432/openremote
KC_DB_USERNAME=openremote
KC_DB_PASSWORD=__CHANGE_ME__               # same as POSTGRES_PASSWORD
KC_HOSTNAME=gps.unitip.global
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080
KC_HTTP_RELATIVE_PATH=/auth
KC_PROXY=edge
KC_PROXY_HEADERS=xforwarded

# ── OpenRemote manager ───────────────────────────────────────────────────────
OR_ADMIN_PASSWORD=__CHANGE_ME__            # was "secret" in Railway — rotate
OR_DB_VENDOR=postgres
OR_DB_HOST=timescaledb
OR_DB_PORT=5432
OR_DB_NAME=openremote
OR_DB_USER=openremote
OR_DB_PASSWORD=__CHANGE_ME__               # same as POSTGRES_PASSWORD
OR_HOSTNAME=gps.unitip.global
OR_HTTP_PORT=8080
OR_SSL_PORT=-1
OR_IDENTITY_PROVIDER=keycloak
OR_KEYCLOAK_HOST=keycloak
OR_KEYCLOAK_PORT=8080
OR_KEYCLOAK_SECURE=false
OR_DEV_MODE=false
OR_SETUP_TYPE=production
OR_SETUP_RUN_ON_RESTART=true               # TODO: flip to `false` after first stable deploy
OR_LOGGING_CONFIG_FILE=/opt/map/logging.properties
OR_MAP_SETTINGS_PATH=/deployment/map/mapsettings.json
OR_MAP_TILES_PATH=/opt/map/mapdata.mbtiles
OR_MANAGER_URL=http://manager:8080
OR_GPS_ADAPTER_URL=http://gps-adapter:8080
OR_TRACCAR_URL=http://traccar:8082

# ── Traccar ──────────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=traccar
ADMIN_EMAIL=admin@unitip.ro
ADMIN_PASSWORD=__CHANGE_ME__               # was "Unitip123!" — rotate
TRACCAR_HOST=0.0.0.0
TRACCAR_PORT=8082
GPS_PORT=5055
TRACCAR_DB_USER=openremote
TRACCAR_DB_PASSWORD=__CHANGE_ME__          # same as POSTGRES_PASSWORD (shared DB)

# ── GPS Adapter (Go, bridges Traccar ↔ OpenRemote) ───────────────────────────
GIN_MODE=release
OPENREMOTE_URL=http://manager:8080
OPENREMOTE_REALM=master
OPENREMOTE_CLIENT_ID=openremote
OPENREMOTE_USER=admin
OPENREMOTE_PASSWORD=__CHANGE_ME__          # was "secret" — rotate
KEYCLOAK_URL=http://keycloak:8080
TRACCAR_URL=http://traccar:8082
TRACCAR_USER=admin@unitip.ro
TRACCAR_PASSWORD=__CHANGE_ME__             # was "Unitip123!" — rotate
ADAPTER_SECRET_KEY=__CHANGE_ME__           # 32-byte hex, shared with nginx

# ── Backup (nightly pg_dump at 02:00) ────────────────────────────────────────
BACKUP_DIR=/backups
# Reuses POSTGRES_* variables from the database section
