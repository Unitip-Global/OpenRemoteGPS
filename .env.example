# ─────────────────────────────────────────────────────────────────────────
# Traccar stack — environment variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Single service, single .env. If you're looking for OR_* / KC_* vars they
# were removed in the 2026-04-24 refactor (OpenRemote + Keycloak gone).
# ─────────────────────────────────────────────────────────────────────────

# ── Shared ──────────────────────────────────────────────────────────────
TZ=Europe/Bucharest

# ── Traccar ─────────────────────────────────────────────────────────────
APP_ENV=production
APP_NAME=traccar

# Seed admin — only the password is actually rotated via the Traccar UI
# after the first start; the env value is the bootstrap seed.
ADMIN_EMAIL=admin@unitip.ro
ADMIN_PASSWORD=__CHANGE_ME__

# Listeners
TRACCAR_HOST=0.0.0.0
TRACCAR_PORT=8082
PORT=8082
GPS_PORT=5027
