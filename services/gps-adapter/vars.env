# Service: GPS-Adapter
PORT=8080
GIN_MODE=release

# OpenRemote (manager API)
OPENREMOTE_URL=http://manager.railway.internal:8080
OPENREMOTE_REALM=master
OPENREMOTE_CLIENT_ID=openremote
OPENREMOTE_USER=admin
OPENREMOTE_PASSWORD=__CHANGE_ME__

# Keycloak (OAuth2 token endpoint)
KEYCLOAK_URL=http://keycloak.railway.internal:8080

# Traccar (source of device positions)
TRACCAR_URL=http://traccar.railway.internal:8082
TRACCAR_USER=admin@unitip.ro
TRACCAR_PASSWORD=__CHANGE_ME__

# Shared secret with nginx
ADAPTER_SECRET_KEY=__CHANGE_ME__
