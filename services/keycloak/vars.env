# Service: keycloak
TZ=Europe/Bucharest

# Admin
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=__CHANGE_ME__

# Database (shared timescaledb)
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://timescaledb.railway.internal:5432/openremote
KC_DB_USERNAME=openremote
KC_DB_PASSWORD=__CHANGE_ME__

# HTTP / hostname
KC_HOSTNAME=gps.unitip.global
KC_HOSTNAME_STRICT=false
KC_HTTP_ENABLED=true
KC_HTTP_PORT=8080
KC_HTTP_RELATIVE_PATH=/auth

# Proxy (behind Railway edge + nginx)
KC_PROXY=edge
KC_PROXY_HEADERS=xforwarded
