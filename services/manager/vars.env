# Service: manager (OpenRemote)
TZ=Europe/Bucharest
PORT=8080

OR_HOSTNAME=gps.unitip.global
OR_HTTP_PORT=8080
OR_SSL_PORT=-1

# Database
OR_DB_VENDOR=postgres
OR_DB_HOST=timescaledb.railway.internal
OR_DB_PORT=5432
OR_DB_NAME=openremote
OR_DB_USER=openremote
OR_DB_PASSWORD=__CHANGE_ME__

# Keycloak
OR_KEYCLOAK_HOST=keycloak.railway.internal
OR_KEYCLOAK_PORT=8080
OR_KEYCLOAK_SECURE=false

# Admin + setup
OR_ADMIN_PASSWORD=__CHANGE_ME__
OR_SETUP_TYPE=production
OR_SETUP_RUN_ON_RESTART=true
