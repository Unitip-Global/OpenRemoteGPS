# Service: OpenRemoteGPS (nginx edge)
# Copy these names into Railway. Values with `__CHANGE_ME__` must not be committed.

TZ=Europe/Bucharest
PORT=8080

# Hostname and upstream routing
OR_HOSTNAME=gps.unitip.global
OR_HTTP_PORT=8080
OR_SSL_PORT=-1
OR_MANAGER_URL=http://manager.railway.internal:8080
OR_GPS_ADAPTER_URL=http://gps-adapter.railway.internal:8080
OR_TRACCAR_URL=http://traccar.railway.internal:8082

# Map / static
OR_MAP_SETTINGS_PATH=/deployment/map/mapsettings.json
OR_MAP_TILES_PATH=/opt/map/mapdata.mbtiles
OR_LOGGING_CONFIG_FILE=/opt/map/logging.properties

# DB (manager setup expects these even on edge)
OR_DB_VENDOR=postgres
OR_DB_HOST=timescaledb.railway.internal
OR_DB_PORT=5432
OR_DB_NAME=openremote
OR_DB_USER=openremote
OR_DB_PASSWORD=__CHANGE_ME__

# Keycloak / identity
OR_IDENTITY_PROVIDER=keycloak
OR_KEYCLOAK_HOST=keycloak.railway.internal
OR_KEYCLOAK_PORT=8080
OR_KEYCLOAK_SECURE=false

# Admin + behaviour
OR_ADMIN_PASSWORD=__CHANGE_ME__
OR_DEV_MODE=false
OR_SETUP_TYPE=production
OR_SETUP_RUN_ON_RESTART=true

# Shared secret between nginx and gps-adapter
ADAPTER_SECRET_KEY=__CHANGE_ME__
