# Service: traccar-transformer (Traccar nested JSON → gps-adapter flat JSON)
PORT=8080

# Where to forward the flattened payload (internal Railway DNS).
ADAPTER_URL=http://gps-adapter.railway.internal:8080/gps/position

# If true, forward positions even when valid=false (device with no GPS fix).
# Default false: skip invalid positions to avoid polluting asset locations.
FORWARD_INVALID=false
