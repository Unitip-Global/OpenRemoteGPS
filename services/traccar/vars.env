# Service: traccar
APP_ENV=production
APP_NAME=traccar

# Admin (used to seed first login + adapter auth)
ADMIN_EMAIL=admin@unitip.ro
ADMIN_PASSWORD=__CHANGE_ME__

# HTTP + device ingest
TRACCAR_HOST=0.0.0.0
TRACCAR_PORT=8082
PORT=8082
GPS_PORT=5055

# Database (shared timescaledb)
TRACCAR_DB_USER=openremote
TRACCAR_DB_PASSWORD=__CHANGE_ME__

# Railway TCP proxy (read-only — Railway sets these):
#   RAILWAY_TCP_APPLICATION_PORT=5055
#   RAILWAY_TCP_PROXY_DOMAIN=gondola.proxy.rlwy.net
#   RAILWAY_TCP_PROXY_PORT=40590

# Shared secret with adapter
ADAPTER_SECRET_KEY=__CHANGE_ME__
