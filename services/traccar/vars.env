# Railway service: traccar
#
# Traccar GPS server — the ONLY running service after the 2026-04-24
# refactor (OpenRemote + Keycloak + adapter removed). Embedded H2 database
# at /opt/traccar/data/database (persistent volume `traccar-volume`), daily
# snapshot via the startCommand wrapper to /opt/traccar/data/backup/.
#
# The `startCommand` override (set on the Railway service, not in this
# file) writes traccar.xml at boot, spawns the backup loop, and execs the
# JVM. Keep this file in sync when the override changes — see
# docs/SECRETS.md.

TZ=Europe/Bucharest

# Traccar base
APP_ENV=production
APP_NAME=traccar

# Admin user — seed for first-time setup. After initial startup the
# password lives in the H2 DB; the env var is just the bootstrap value.
ADMIN_EMAIL=admin@unitip.ro
ADMIN_PASSWORD=__CHANGE_ME__

# HTTP listener. Served publicly at https://gps.unitip.global via the
# custom domain attached to this service (Railway edge proxies :8082).
TRACCAR_HOST=0.0.0.0
TRACCAR_PORT=8082
PORT=8082

# Device TCP ingest. Teltonika Codec 8 / 8E connect here.
# Public via Railway TCP proxy: shortline.proxy.rlwy.net:57840 → :5027.
GPS_PORT=5027

# Backup behaviour (documented for operator reference — actual retention
# is enforced by the `find -mtime +N -delete` clause inside the
# startCommand wrapper's backup script).
TRACCAR_BACKUP_RETENTION_DAYS=14
